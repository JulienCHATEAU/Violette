# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Plant recognition (primary) ---
# Sign up at https://web.plant.id/api-access-request/ — free tier available
PLANT_ID_API_KEY=""

# --- Claude API (push messages + vision fallback) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# --- Web Push (VAPID) ---
# Generate with:  npm run vapid:generate
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:julien@beehelp.fr"
# Public key must also be exposed to the browser:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Cron security ---
# Any random string; required on /api/cron/* requests as `x-cron-secret` header
CRON_SECRET="change-me"

# --- Timezone (for quiet hours calc) ---
TZ="Europe/Paris"

# --- Basic Auth (prod / Railway) ---
# Laisse vide en dev local → l'auth est désactivée.
BASIC_AUTH_USER=""
BASIC_AUTH_PASSWORD=""

# --- Cron worker target ---
# En dev local : http://localhost:3000
# Sur Railway (service cron) : http://web.railway.internal:3000
APP_URL="http://localhost:3000"
