# Production env template — paste these into Northflank service "web"
# DO NOT commit real values. Generate them with the commands below.

# --- Database ---
# SQLite file lives on the persistent volume mounted at /data
DATABASE_URL="file:/data/prod.db"

# --- Auth (signs the session JWT cookie) ---
# Generate locally:  openssl rand -base64 48
AUTH_SECRET=""

# --- Web Push (VAPID) ---
# Generate locally:  npm run vapid:generate
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:julien@beehelp.fr"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Cron security ---
# Shared between the web service and the scheduled jobs.
# Generate locally:  openssl rand -hex 32
CRON_SECRET=""

# --- Timezone (for quiet hours calc) ---
TZ="Europe/Paris"

# --- Runtime ---
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"

# --- Cron worker target (set on the scheduled jobs, not on the web service) ---
# Set to the public HTTPS URL of the web service once it is deployed,
# e.g. https://web--violette-xxxx.code.run
APP_URL=""
