// Violette — schéma Prisma
// Run:  npx prisma migrate dev --name <name>

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plants            Plant[]
  pushSubscriptions PushSubscription[]
}

model Plant {
  id                    String   @id @default(cuid())
  name                  String
  nickname              String?
  description           String?
  species               String?
  wateringFrequencyDays Int      @default(7)
  lastWateredAt         DateTime @default(now())
  sunlightExposure      String   @default("indirect_light")
  humidity              String   @default("medium")
  temperatureRange      String?
  notes                 String?
  photo                 Bytes?
  photoMime             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  wateringLogs  WateringLog[]
  pushMessages  PushMessage[]

  @@index([ownerId])
}

model WateringLog {
  id        String   @id @default(cuid())
  plantId   String
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  wateredAt DateTime @default(now())
  note      String?

  @@index([plantId, wateredAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  wateringRemindersEnabled Boolean @default(true)
  greetingsEnabled         Boolean @default(true)
  greetingsPerDay          Int     @default(1)
  quietHoursStart          Int?    @default(22)
  quietHoursEnd            Int?    @default(8)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushMessage {
  id         String   @id @default(cuid())
  plantId    String?
  plant      Plant?   @relation(fields: [plantId], references: [id], onDelete: SetNull)
  kind       String   // watering_due | greeting
  body       String
  sentAt     DateTime @default(now())
  templateId String?

  @@index([plantId, kind, sentAt])
  @@index([templateId, sentAt])
}
